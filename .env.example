# ─── FIREBASE CONFIG ────────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Web App
REACT_APP_FIREBASE_API_KEY=your_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id

# ─── APPLOVIN MAX ────────────────────────────────────────────────────────────
# Get these from: AppLovin Dashboard → Ad Units → Rewarded Video
REACT_APP_APPLOVIN_SDK_KEY=your_applovin_sdk_key
REACT_APP_APPLOVIN_REWARDED_AD_UNIT_WEB=your_web_placement_id
REACT_APP_APPLOVIN_REWARDED_AD_UNIT_ANDROID=your_android_placement_id

# ─── IRONSOURCE / UNITY LEVELPLAY (Alternative) ─────────────────────────────
# Get these from: IronSource Dashboard → Ad Units
REACT_APP_IRONSOURCE_APP_KEY=your_ironsource_app_key

# ─── PAYPAL PAYOUTS ──────────────────────────────────────────────────────────
# NEVER put these in the frontend — these go in Firebase Cloud Functions only
# functions/.env (separate file)
# PAYPAL_CLIENT_ID=your_paypal_client_id
# PAYPAL_CLIENT_SECRET=your_paypal_client_secret
# PAYPAL_MODE=sandbox   # change to 'live' for production

# ─── APP CONFIG ──────────────────────────────────────────────────────────────
REACT_APP_MIN_WITHDRAWAL=1.00
REACT_APP_ADMIN_EMAIL=admin@yourdomain.com
